# Server
NODE_ENV=development
PORT=3000

# Database (SQLite for local prototype)
DATABASE_URL="file:./dev.db"

# JWT — use a long random string in production (min 32 chars)
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=1h

# bcrypt cost factor (10–12 recommended)
BCRYPT_ROUNDS=12

# OTP settings
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

# Account lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

# SMTP email delivery
# Do not commit real SMTP passwords. Put real values in local .env only.
SMTP_HOST=mail.spacemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-smtp-username@example.com
SMTP_PASS=replace-with-local-secret-only
SMTP_FROM="SecureFin <your-smtp-username@example.com>"

# Cookie settings
# Set COOKIE_SECURE=true in production behind HTTPS/TLS
COOKIE_SECURE=false
COOKIE_NAME=securefin_token

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5
OTP_RATE_LIMIT_MAX=5
REGISTER_RATE_LIMIT_MAX=10
