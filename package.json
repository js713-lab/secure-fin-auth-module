{
  "name": "securefin-auth-module",
  "version": "1.0.0",
  "description": "Secure User Authentication & Authorization module for SecureFin Sdn. Bhd.",
  "main": "src/server.js",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "test": "NODE_ENV=test jest --runInBand --forceExit",
    "seed": "node prisma/seed.js",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "postinstall": "prisma generate && node scripts/sync-ogl-vendor.js",
    "sync:ogl": "node scripts/sync-ogl-vendor.js"
  },
  "keywords": [
    "authentication",
    "authorization",
    "security",
    "mfa",
    "rbac"
  ],
  "author": "SecureFin ITS69405 Group",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "nodemailer": "^9.0.3",
    "ogl": "^1.0.11",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "jest": "^30.0.3",
    "prisma": "^5.22.0",
    "supertest": "^7.1.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 30000
  }
}
